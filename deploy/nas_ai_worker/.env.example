# Cloud quant-lab SSH endpoint. The NAS initiates every connection.
QLAB_SSH_HOST=replace-with-cloud-host-or-domain
QLAB_SSH_PORT=22
QLAB_SSH_USER=quantai
QLAB_REMOTE_QUEUE_ROOT=/var/lib/quant-lab/ai_queue
QLAB_SSH_KEY_PATH=/run/secrets/qlab_ssh_key
QLAB_SSH_KNOWN_HOSTS=/run/secrets/known_hosts

# Existing NAS-local Responses-compatible proxy.
# Rotate the token that was pasted into chat before putting the new value here.
# If the proxy listens only on the NAS host, use host.docker.internal instead of a LAN IP.
CLIPROXY_BASE_URL=http://host.docker.internal:8317/v1
CLIPROXY_API_KEY=replace-with-rotated-token
OPENAI_MODEL=gpt-5.6-sol
OPENAI_REASONING_EFFORT=xhigh

WORKER_ID=ugreen-nas-ai-01
WORKER_DATA_DIR=/data
POLL_INTERVAL_SECONDS=300
RUN_ONCE=false
API_TIMEOUT_SECONDS=900
API_RETRIES=3
MAX_OUTPUT_TOKENS_STAGE1=16000
MAX_OUTPUT_TOKENS_STAGE2=24000
LOG_LEVEL=INFO
NAS_EXPORT_ACCEPTED_ROOT=/exports/accepted
NAS_EXPORT_INDEX_PATH=/exports/accepted_index.json
NAS_EXPORT_WORKER_PUBLIC_KEY=/run/secrets/nas_export_public_key
NAS_EXPORT_WORKER_KEY_ID=nas-export-v1
NAS_EXPORT_DATA_HOST_PATH=/volume/path/quant-export/data
