NAS_EXPORT_ACCEPTED_ROOT=/exports/accepted
NAS_EXPORT_INDEX_PATH=/exports/accepted_index.json
NAS_EXPORT_WORKER_STATUS_PATH=/exports/status/worker.json
NAS_DOWNLOAD_SIGNING_SECRET_FILE=/run/secrets/nas-download.key
NAS_DOWNLOAD_KEY_ID=nas-download-v1
NAS_DOWNLOAD_TOKEN_TTL_SECONDS=1800
NAS_DOWNLOAD_BIND_HOST=127.0.0.1
NAS_DOWNLOAD_PORT=8788
NAS_EXPORT_DATA_HOST_PATH=/volume/path/quant-export/data
