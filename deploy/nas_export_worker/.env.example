WORKER_SIGNING_KEY_PATH=/run/secrets/nas_export_signing_key
WORKER_KEY_ID=nas-export-v1
CLOUD_PUBLIC_KEY_PATH=/run/secrets/cloud_export_public_key
CLOUD_KEY_ID=cloud-export-v1
BUILD_GIT_COMMIT=0000000000000000000000000000000000000000
BUILD_TIMESTAMP=unknown
NAS_EXPORT_WORKER_MEMORY_LIMIT=8g
POLL_INTERVAL_SECONDS=30
HEARTBEAT_SECONDS=30
RUN_ONCE=false
MAX_SNAPSHOT_BYTES=21474836480
MAX_PACK_BYTES=10737418240
MIN_FREE_DISK_BYTES=21474836480
NAS_EXPORT_ACCEPTED_ROOT=/data/accepted
NAS_EXPORT_INDEX_PATH=/data/accepted_index.json
NAS_EXPORT_WORKER_STATUS_PATH=/data/status/worker.json
NAS_HEAVY_JOB_LOCK_PATH=/runtime/heavy-job.lock
