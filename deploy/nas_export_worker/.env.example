NAS_EXPORT_MAX_TOTAL_GB=200
NAS_EXPORT_MIN_KEEP_PACKS=30
RECEIPT_WAIT_SECONDS=900
LOG_LEVEL=INFO
NAS_EXPORT_DATA_HOST_PATH=/volume/path/quant-export/data
NAS_RUNTIME_HOST_PATH=/volume/path/quant-runtime
