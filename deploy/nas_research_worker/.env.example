QUANT_RESEARCH_CLOUD_HOST=qyun2.hrhome.top
QUANT_RESEARCH_CLOUD_PORT=22
QUANT_RESEARCH_CLOUD_USER=quant-research
QUANT_LAB_RESEARCH_QUEUE_ROOT=/var/lib/quant-lab/research_queue
QUANT_RESEARCH_SSH_KEY_PATH=/run/secrets/qlab_ssh_key
QUANT_RESEARCH_KNOWN_HOSTS_PATH=/run/secrets/known_hosts
QUANT_RESEARCH_TASK_PUBLIC_KEY_PATH=/run/secrets/cloud_research_task_public_key
QUANT_RESEARCH_TASK_KEY_ID=cloud-research-task-v1
QUANT_RESEARCH_WORKER_SIGNING_KEY_PATH=/run/secrets/nas_research_signing_key
QUANT_RESEARCH_WORKER_KEY_ID=nas-research-worker-v1
QUANT_RESEARCH_WORKER_ID=nas-research-worker-01
QUANT_RESEARCH_DATA_ROOT=/data
QUANT_HEAVY_JOB_LOCK=/runtime/heavy-job.lock
BUILD_GIT_COMMIT=0000000000000000000000000000000000000000
BUILD_TIMESTAMP=unknown
NAS_RESEARCH_WORKER_MEMORY_LIMIT=8g
NAS_RESEARCH_DATA_HOST_PATH=/volume1/docker/quant-research/data
NAS_RUNTIME_HOST_PATH=/volume1/docker/quant-runtime
RUN_ONCE=false
POLL_SECONDS=30
HEARTBEAT_SECONDS=30
BATCH_FETCH_WORKERS=3
MIN_FREE_DISK_BYTES=21474836480
MAX_SNAPSHOT_BYTES=268435456000
MAX_RESULT_BYTES=2147483648
LOG_LEVEL=INFO
