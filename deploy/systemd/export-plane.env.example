QUANT_LAB_NAS_EXPORT_ENABLED=1
QUANT_LAB_LOCAL_EXPORT_ENABLED=0
QUANT_LAB_WEB_LOCAL_EXPORT_ENABLED=0
QUANT_LAB_EXPORT_QUEUE_ROOT=/var/lib/quant-lab/export_queue
QUANT_LAB_LAKE_ROOT=/var/lib/quant-lab/lake
QUANT_LAB_EXPORT_TASK_PRIVATE_KEY_PATH=/etc/quant-lab/keys/cloud-export.key
QUANT_LAB_EXPORT_TASK_KEY_ID=cloud-export-v1
QUANT_LAB_EXPORT_WORKER_COMMIT=0000000000000000000000000000000000000000
QUANT_LAB_NAS_WORKER_PUBLIC_KEY_PATH=/etc/quant-lab/keys/nas-export.pub
QUANT_LAB_NAS_WORKER_KEY_ID=nas-export-v1
QUANT_LAB_NAS_EXPORT_BASE_URL=http://nas-vpn.example.invalid:8788
QUANT_LAB_NAS_DOWNLOAD_SIGNING_SECRET_FILE=/etc/quant-lab/secrets/nas-download.key
QUANT_LAB_NAS_DOWNLOAD_KEY_ID=nas-download-v1
QUANT_LAB_NAS_DOWNLOAD_TOKEN_TTL_SECONDS=1800
