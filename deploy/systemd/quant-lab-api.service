[Unit]
Description=quant-lab read-only FastAPI API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=quantlab
Group=quantlab
SupplementaryGroups=quant-export
WorkingDirectory=/opt/quant-lab
Environment=PYTHONUNBUFFERED=1
Environment=QUANT_LAB_LAKE_ROOT=/var/lib/quant-lab/lake
Environment=QUANT_LAB_API_METRICS_ASYNC_FLUSH=1
Environment=QUANT_LAB_API_METRICS_FLUSH_ROWS=1000
Environment=QUANT_LAB_API_METRICS_FLUSH_SECONDS=300
Environment=QUANT_LAB_API_METRICS_FLUSH_JOIN_SECONDS=0.25
Environment=QUANT_LAB_API_METRICS_RESPONSE_CACHE_SECONDS=12
Environment=QUANT_LAB_API_METRICS_PRODUCTION_CLIENT_HOSTS=43.156.105.125
EnvironmentFile=-/etc/quant-lab/quant_lab_api.env
EnvironmentFile=-/etc/quant-lab/export-plane.env
Environment=QUANT_LAB_RISK_PERMISSION_TTL_SECONDS=5400
Environment=QUANT_LAB_WEB_ON_DEMAND_EXPORT=true
Environment=QUANT_LAB_WEB_EXPORT_BACKGROUND=true
Environment=QUANT_LAB_WEB_EXPORT_BACKGROUND_TRIGGER=request_file
Environment=QUANT_LAB_WEB_EXPORT_STATUS_STALE_SECONDS=5400
Environment=QUANT_LAB_WEB_EXPORT_REQUEST_PICKUP_STALE_SECONDS=5400
Environment=QUANT_LAB_BIGSCREEN_STALE_GRACE_SECONDS=0
Environment=QUANT_LAB_WEB_V2_SMOKE_REQUIRE_STATUS=1
ExecStart=/opt/quant-lab/.venv/bin/uvicorn quant_lab.api.main:app --host 0.0.0.0 --port 8027
Restart=always
RestartSec=5
MemoryMax=1536M
CPUQuota=80%
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
