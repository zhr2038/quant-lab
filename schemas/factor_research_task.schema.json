{
  "$id": "https://schemas.hrhome.top/quant-lab/factor_research_task.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "as_of_date": {
      "format": "date",
      "title": "As Of Date",
      "type": "string"
    },
    "automatic_promotion": {
      "const": false,
      "default": false,
      "title": "Automatic Promotion",
      "type": "boolean"
    },
    "end_date": {
      "format": "date",
      "title": "End Date",
      "type": "string"
    },
    "factor_research_schema_version": {
      "maxLength": 80,
      "minLength": 1,
      "title": "Factor Research Schema Version",
      "type": "string"
    },
    "hypothesis_ids": {
      "items": {
        "type": "string"
      },
      "maxItems": 6,
      "minItems": 1,
      "title": "Hypothesis Ids",
      "type": "array"
    },
    "hypothesis_registry_digest": {
      "maxLength": 64,
      "minLength": 64,
      "title": "Hypothesis Registry Digest",
      "type": "string"
    },
    "lease_seconds": {
      "default": 7200,
      "maximum": 86400,
      "minimum": 60,
      "title": "Lease Seconds",
      "type": "integer"
    },
    "live_order_effect": {
      "const": "none",
      "default": "none",
      "title": "Live Order Effect",
      "type": "string"
    },
    "max_attempts": {
      "default": 3,
      "maximum": 10,
      "minimum": 1,
      "title": "Max Attempts",
      "type": "integer"
    },
    "max_history_days": {
      "maximum": 1095,
      "minimum": 1,
      "title": "Max History Days",
      "type": "integer"
    },
    "max_live_notional_usdt": {
      "const": 0,
      "default": 0,
      "title": "Max Live Notional Usdt",
      "type": "integer"
    },
    "quant_lab_commit": {
      "maxLength": 40,
      "minLength": 40,
      "title": "Quant Lab Commit",
      "type": "string"
    },
    "requested_at": {
      "format": "date-time",
      "title": "Requested At",
      "type": "string"
    },
    "research_only": {
      "const": true,
      "default": true,
      "title": "Research Only",
      "type": "boolean"
    },
    "schema_version": {
      "const": "quant_lab_factor_research_task.v1",
      "default": "quant_lab_factor_research_task.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "selected_v5_bundle_id": {
      "maxLength": 512,
      "minLength": 1,
      "title": "Selected V5 Bundle Id",
      "type": "string"
    },
    "signature": {
      "minLength": 1,
      "title": "Signature",
      "type": "string"
    },
    "signature_key_id": {
      "maxLength": 120,
      "minLength": 1,
      "title": "Signature Key Id",
      "type": "string"
    },
    "snapshot_id": {
      "maxLength": 180,
      "minLength": 1,
      "title": "Snapshot Id",
      "type": "string"
    },
    "snapshot_manifest_sha256": {
      "maxLength": 64,
      "minLength": 64,
      "title": "Snapshot Manifest Sha256",
      "type": "string"
    },
    "source_input_digest": {
      "maxLength": 64,
      "minLength": 64,
      "title": "Source Input Digest",
      "type": "string"
    },
    "start_date": {
      "format": "date",
      "title": "Start Date",
      "type": "string"
    },
    "task_id": {
      "maxLength": 180,
      "minLength": 1,
      "title": "Task Id",
      "type": "string"
    },
    "task_type": {
      "const": "factor_research",
      "default": "factor_research",
      "title": "Task Type",
      "type": "string"
    },
    "test_count": {
      "maximum": 54,
      "minimum": 1,
      "title": "Test Count",
      "type": "integer"
    },
    "trial_ids": {
      "items": {
        "type": "string"
      },
      "maxItems": 54,
      "minItems": 1,
      "title": "Trial Ids",
      "type": "array"
    },
    "trial_ledger_digest": {
      "maxLength": 64,
      "minLength": 64,
      "title": "Trial Ledger Digest",
      "type": "string"
    }
  },
  "required": [
    "task_id",
    "snapshot_id",
    "as_of_date",
    "start_date",
    "end_date",
    "max_history_days",
    "hypothesis_ids",
    "trial_ids",
    "test_count",
    "quant_lab_commit",
    "factor_research_schema_version",
    "hypothesis_registry_digest",
    "trial_ledger_digest",
    "source_input_digest",
    "selected_v5_bundle_id",
    "snapshot_manifest_sha256",
    "requested_at",
    "signature_key_id",
    "signature"
  ],
  "title": "FactorResearchTask",
  "type": "object"
}
