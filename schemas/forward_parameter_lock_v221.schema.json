{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quant-lab.local/schemas/forward_parameter_lock_v221.schema.json",
  "title": "Quant Lab Forward Parameter Lock v2.2.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "strategy_id",
    "strategy_version",
    "hypothesis_type",
    "approval_state",
    "parameters_locked",
    "factor",
    "factor_formula",
    "factor_lookback_hours",
    "btc_trend_filter",
    "btc_trend_lookback_hours",
    "top_n",
    "weighting",
    "rebalance_hours",
    "holding_hours",
    "decision_delay_bars",
    "entry_cost_bps",
    "exit_cost_bps",
    "round_trip_cost_bps",
    "max_decision_latency_seconds",
    "minimum_forward_days",
    "minimum_completed_cycles",
    "minimum_symbol_trades",
    "minimum_data_coverage",
    "minimum_benchmark_fill_coverage",
    "minimum_schedule_coverage",
    "maximum_single_symbol_contribution",
    "strategy_code_commit",
    "strategy_code_hash",
    "reporting_code_hash",
    "service_unit_hash",
    "timer_unit_hash",
    "runner_script_hash",
    "schedule_anchor",
    "schedule_timezone",
    "execution_mode",
    "production_alpha",
    "live_opening_enabled",
    "created_at",
    "sha256"
  ],
  "properties": {
    "strategy_id": {"const": "low_vol_btc_60d_trend_top3_score_120h_v221"},
    "strategy_version": {"const": "2.2.1"},
    "hypothesis_type": {"const": "POST_HOC_HYPOTHESIS"},
    "approval_state": {"const": "PAPER_ONLY"},
    "parameters_locked": {"const": true},
    "factor": {"const": "low_vol_20d"},
    "factor_formula": {"const": "-rolling_std(ret_1h, 480)"},
    "factor_lookback_hours": {"const": 480},
    "btc_trend_filter": {"const": true},
    "btc_trend_lookback_hours": {"const": 1440},
    "btc_trend_description": {"const": "BTC 60-day SMA trend filter"},
    "top_n": {"const": 3},
    "weighting": {"const": "score"},
    "universe": {"const": "dynamic_top20_v1"},
    "maximum_single_position_weight": {"const": 0.5},
    "rebalance_hours": {"const": 120},
    "holding_hours": {"const": 120},
    "decision_delay_bars": {"const": 1},
    "strategy_type": {"const": "long_only_spot"},
    "entry_cost_bps": {"const": 15.0},
    "exit_cost_bps": {"const": 15.0},
    "round_trip_cost_bps": {"const": 30.0},
    "max_decision_latency_seconds": {"const": 3600},
    "minimum_forward_days": {"const": 30},
    "minimum_completed_cycles": {"const": 6},
    "minimum_symbol_trades": {"const": 12},
    "minimum_data_coverage": {"const": 0.95},
    "minimum_benchmark_fill_coverage": {"const": 0.95},
    "minimum_schedule_coverage": {"const": 0.95},
    "maximum_single_symbol_contribution": {"const": 0.5},
    "maximum_drawdown": {"const": 0.3},
    "strategy_code_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "strategy_code_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "reporting_code_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "locked_source_files": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/sourceHash"}
    },
    "reporting_source_files": {
      "type": "array",
      "items": {"$ref": "#/$defs/sourceHash"}
    },
    "service_unit_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "timer_unit_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "runner_script_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "schedule_anchor": {"const": "2026-07-18T22:00:00+00:00"},
    "schedule_timezone": {"const": "UTC"},
    "runner_version": {"const": "quant_lab_low_vol_forward.v2.2.1"},
    "execution_mode": {"const": "PAPER"},
    "production_alpha": {"const": "FROZEN"},
    "live_opening_enabled": {"const": false},
    "live_order_effect": {"const": "none"},
    "automatic_promotion": {"const": false},
    "universe_definition_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "cost_model_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "created_at": {"type": "string", "format": "date-time"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "$defs": {
    "sourceHash": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
